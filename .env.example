# FXRoute - Environment Configuration

# Required: Path to your music library
# Supports ~ and $HOME expansion
# Example: MUSIC_ROOT=~/Music
MUSIC_ROOT=~/Music

# Optional settings
DOWNLOADS_SUBDIR=incoming
# Leave unset to keep the source format for URL downloads whenever possible.
# Set only if you explicitly want yt-dlp downloads transcoded, for example:
# DOWNLOAD_TRANSCODE_FORMAT=mp3
LOG_LEVEL=INFO

# Server configuration
HOST=0.0.0.0
PORT=8000

# Maximum concurrent downloads (V1: must be 1)
MAX_DOWNLOADS=1
